generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String      @id @default(cuid())
  name             String
  email            String      @unique
  emailVerified    Boolean
  image            String?
  createdAt        DateTime
  updatedAt        DateTime
  twoFactorEnabled Boolean?
  banExpires       DateTime?
  banReason        String?
  banned           Boolean?
  displayUsername  String?
  isAnonymous      Boolean?
  role             String?
  username         String?     @unique
  accounts         Account[]
  blogPosts        BlogPost[]
  reviewedComments BlogComment[] @relation("BlogCommentReviewer")
  sessions         Session[]
  twoFactors       TwoFactor[]

  @@map("user")
}

model TwoFactor {
  id          String @id @default(cuid())
  secret      String
  backupCodes String
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("twoFactor")
}

model Session {
  id             String   @id @default(cuid())
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime
  updatedAt      DateTime
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime
  updatedAt  DateTime

  @@map("verification")
}

model VisitorLog {
  id                   String   @id @default(cuid())
  visitorId            String
  ipHash               String
  path                 String
  referrer             String   @default("direct")
  referrerSource       String   @default("direct")
  userAgent            String
  isUniqueDailyVisitor Boolean  @default(false)
  visitedAt            DateTime @default(now())

  @@index([visitedAt])
  @@index([path, visitedAt])
  @@index([referrerSource, visitedAt])
  @@index([visitorId, visitedAt])
  @@map("visitorLog")
}

model Message {
  id          String        @id @default(cuid())
  senderName  String
  senderEmail String
  subject     String
  body        String
  status      MessageStatus @default(UNREAD)
  readAt      DateTime?
  archivedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@map("message")
}

model Testimonial {
  id         String              @id @default(cuid())
  name       String
  role       String
  company    String?
  message    String
  rating     Int
  relation   TestimonialRelation
  status     TestimonialStatus   @default(PENDING)
  featured   Boolean             @default(false)
  reviewedAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([status])
  @@index([featured])
  @@index([status, featured])
  @@index([createdAt])
  @@map("testimonial")
}

model CvDownloadLog {
  id           String   @id @default(cuid())
  ipHash       String
  userAgent    String
  referrer     String   @default("direct")
  downloadedAt DateTime @default(now())

  @@index([downloadedAt])
  @@index([ipHash, downloadedAt])
  @@map("cvDownloadLog")
}

model ResumeAsset {
  id            String   @id @default(cuid())
  storageKey    String   @unique @default("primary")
  downloadUrl   String
  fileName      String?
  fileSizeBytes Int?
  mimeType      String   @default("application/pdf")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("resumeAsset")
}

model ProfileContent {
  id              String   @id @default(cuid())
  storageKey      String   @unique @default("primary")
  fullName        String
  headline        String
  shortIntro      String
  about           String
  location        String
  email           String
  phone           String
  availability    String
  primaryCta      String
  profilePhotoUrl String?
  socialLinks     Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("profileContent")
}

model Skill {
  id        String   @id @default(cuid())
  name      String
  category  String
  level     String
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([featured])
  @@index([category, featured])
  @@map("skill")
}

model BlogPost {
  id                    String         @id @default(cuid())
  title                 String
  slug                  String         @unique
  excerpt               String
  content               String
  tags                  String[]
  category              String
  coverImagePlaceholder String?
  status                BlogPostStatus @default(DRAFT)
  featured              Boolean        @default(false)
  publishDate           DateTime?
  readingTime           String
  seoTitle              String?
  seoDescription        String?
  authorName            String
  authorUserId          String
  authorUser            User           @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  comments              BlogComment[]
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([status])
  @@index([featured])
  @@index([publishDate])
  @@index([authorUserId])
  @@index([status, featured, publishDate])
  @@map("blogPost")
}

model BlogComment {
  id               String            @id @default(cuid())
  blogPostId       String
  blogPost         BlogPost          @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  parentId         String?
  parent           BlogComment?      @relation("BlogCommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies          BlogComment[]     @relation("BlogCommentThread")
  displayName      String
  email            String
  body             String
  status           BlogCommentStatus @default(PENDING)
  reviewedAt       DateTime?
  reviewedByUserId String?
  reviewedByUser   User?             @relation("BlogCommentReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  ipHash           String
  fingerprint      String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([blogPostId])
  @@index([blogPostId, status, createdAt])
  @@index([blogPostId, parentId, status, createdAt])
  @@index([parentId])
  @@index([status])
  @@index([reviewedByUserId])
  @@index([fingerprint])
  @@index([ipHash, createdAt])
  @@map("blogComment")
}

enum MessageStatus {
  UNREAD
  READ
  ARCHIVED
}

enum TestimonialStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TestimonialRelation {
  CLIENT
  COLLEAGUE
  MENTOR
  OTHER
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BlogCommentStatus {
  PENDING
  APPROVED
  REJECTED
  SPAM
}
